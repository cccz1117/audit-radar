# =============================================================================
# Python
# =============================================================================
# Byte-compiled / optimized / DLL files
**/__pycache__/
**/*.py[cod]
**/*$py.class

# C extensions
**/*.so

# Distribution / packaging
**/.Python
**/build/
**/develop-eggs/
**/dist/
**/downloads/
**/eggs/
**/.eggs/
**/lib/
**/lib64/
**/parts/
**/sdist/
**/var/
**/wheels/
**/*.egg-info/
**/.installed.cfg
**/*.egg

# PyInstaller
**/*.manifest
**/*.spec

# Installer logs
**/pip-log.txt
**/pip-delete-this-directory.txt

# Unit test / coverage reports
**/htmlcov/
**/.tox/
**/.nox/
**/.coverage
**/.coverage.*
**/.cache
**/nosetests.xml
**/coverage.xml
**/*.cover
**/.hypothesis/
**/.pytest_cache/

# =============================================================================
# Virtual environments
# =============================================================================
**/.venv/
**/venv/
**/ENV/
**/env/

# =============================================================================
# Secrets & API keys
# =============================================================================
# Dotenv files are the most common way to store API keys and secrets locally.
# Ignore all .env files and any dotenv-style variants.
**/.env
**/.env.*
!**/.env.example
!**/.env.template

# Local secret/config overrides
**/secrets.json
**/secrets.yaml
**/secrets.yml
**/local_config.py
**/local_settings.py
**/config.local.py

# API key files (common naming patterns)
**/*api_key*
**/*apikey*
**/*api-secret*
**/*api_secret*

# =============================================================================
# IDE / Editor
# =============================================================================
**/.idea/
**/.vscode/
**/*.swp
**/*.swo
**/*~
**/.DS_Store

# =============================================================================
# Logs & temporary files
# =============================================================================
**/*.log
**/logs/
**/tmp/
**/temp/
**/*.tmp

# =============================================================================
# Project-specific
# =============================================================================
# Ignore any future local data or output directories you might create
**/data/
**/output/
**/outputs/
